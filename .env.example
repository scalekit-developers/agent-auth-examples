# Scalekit Agent Auth — Environment Variables
# Copy this file to .env and fill in your values.
# Get these from: app.scalekit.com → Developers → Settings → API Credentials

SCALEKIT_CLIENT_ID=skc_your_client_id_here
SCALEKIT_CLIENT_SECRET=skcs_your_client_secret_here
SCALEKIT_ENVIRONMENT_URL=https://your-subdomain.scalekit.dev

# Optional model provider settings for framework examples.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_ADK_MODEL=gemini-2.0-flash
SCALEKIT_MCP_URL=
SCALEKIT_MCP_CONFIG_NAME=gmail-user-tools
